config ARCH_IS_SET
	bool
	default y

config ARCH
	string
	default "hexagon"

config HEXAGON
	bool
	default y
	select ARCH_HAS_THREAD_LOCAL_STORAGE if CPU_HAS_TLS
	select ARCH_HAS_THREAD_ABORT
	select ARCH_HAS_GDBSTUB
	select USE_SWITCH
	select USE_SWITCH_SUPPORTED
	help
	  Qualcomm Hexagon DSP architecture

config HEXAGON_VM
	bool "Hexagon Virtual Machine support"
	default y
	help
	  Enable Hexagon Virtual Machine support. This provides VM
	  instructions for interrupt control, timer operations, and
	  memory management.

config HEXAGON_HW_THREADS
	bool "Enable hardware thread support"
	default n
	help
	  Enable support for multiple hardware threads using Hexagon VM operations.
	  This allows threads to be assigned to specific virtual processors.

config HEXAGON_HW_THREADS_MAX
	int "Maximum number of hardware threads"
	default 4
	range 1 6
	depends on HEXAGON_HW_THREADS
	help
	  Maximum number of hardware threads supported by the Hexagon core

menu "Hexagon Options"

config HEXAGON_VM_VERSION
	hex "Hexagon VM version"
	default 0x0700
	help
	  Version of Hexagon VM interface to use

config HEXAGON_PLATFORM_INTEGRATION
	bool "Enable Hexagon platform integration features"
	default y
	help
	  Enable comprehensive platform integration features for Hexagon
	  including advanced debugging, power management, and testing support.

config HEXAGON_QEMU_SUPPORT
	bool "Enhanced QEMU support"
	default y if QEMU_TARGET
	help
	  Enable enhanced QEMU support with debugging and networking features.

config HEXAGON_COMPREHENSIVE_TESTING
	bool "Comprehensive test suite support"
	default y if HEXAGON_PLATFORM_INTEGRATION
	help
	  Enable support for running the complete Zephyr test suite on Hexagon.

endmenu

source "arch/hexagon/core/Kconfig"
