/dts-v1/;

#include <mem.h>

/ {
	model = "QEMU Hexagon Virtual Machine";
	compatible = "qemu,hexagon-virt";
	#address-cells = <1>;
	#size-cells = <1>;

	cpus {
		#address-cells = <1>;
		#size-cells = <0>;

		cpu0: cpu@0 {
			device_type = "cpu";
			compatible = "qcom,hexagon";
			reg = <0>;
		};
	};

	chosen {
		zephyr,sram = &sram0;
		//zephyr,flash = &flash0;
		zephyr,console = &uart0;
	};

	memory@80000000 {
		device_type = "memory";
		reg = <0x80000000 DT_SIZE_M(32)>;
	};

	sram0: memory@c0000000 {
		device_type = "memory";
		compatible = "mmio-sram";
		reg = <0xc0000000 DT_SIZE_M(16)>;
	};

/*
	flash0: flash@c0000000 {
		device_type = "memory";
		compatible = "soc-nv-flash";
		reg = <0xc0000000 DT_SIZE_M(16)>;
	};
*/

	uart0: uart@10000000 {
		compatible = "pl011";
		reg = <0x10000000 0x1000>;
//		interrupts = <15>;
		clock-frequency = <1843200>;
		reg-shift = <0>;
		status = "okay";
	};
};
